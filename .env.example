# Chatwork API設定
CHATWORK_TOKEN=your_chatwork_api_token_here
CHATWORK_ROOM_ID=your_room_id_here

# Cron認証（ランダムな文字列を生成して設定）
CRON_SECRET=your_random_secret_here

# メンバーCSV設定（LocalStorageからエクスポートしたJSON）
# フォーマット: [{"name":"加藤","sheets":{"シート名":"https://docs.google.com/..."}}, ...]
MEMBERS_CSV_CONFIG=[]
